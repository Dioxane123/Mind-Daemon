# Mind Daemon 配置文件模板
# 复制此文件为 .env 并填入你的实际凭据信息

# ===== Emotiv BCI 设备配置 =====
# 从 https://emotiv.com 开发者账户获取
EMOTIV_CLIENT_ID=your_emotiv_client_id_here
EMOTIV_CLIENT_SECRET=your_emotiv_client_secret_here

# ===== MiniMax LLM API 配置 =====
# 从 https://api.minimax.chat 获取
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1/text/chatcompletion_v2

# ===== RDK X5 远程连接配置 =====
# `192.168.128.10` 为通过Type-C闪连接口连接开发板时默认地址
RDK_HOST=192.168.128.10
RDK_USER=root
RDK_PASSWORD=root

# ===== 系统配置 =====
# 用户ID (用于数据记录)
USER_ID=default_user

# CSV数据记录目录
CSV_OUTPUT_DIR=bci_data

# 音乐文件目录
MUSIC_DIR=music

# ===== 调试配置 =====
# 启用调试模式 (true/false)
DEBUG_MODE=false

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===== BCI 分析参数 =====
# 数据窗口大小
BCI_WINDOW_SIZE=100

# 分析间隔 (秒)
BCI_ANALYSIS_INTERVAL=1.0

# 动作冷却时间 (秒)
ACTION_COOLDOWN=30.0

# ===== 外设控制配置 =====
# 光晕效果持续时间 (秒)
HALO_DURATION=5.0

# 音乐渐变时间 (秒)  
MUSIC_FADE_DURATION=10.0

# 默认音量 (0.0-1.0)
DEFAULT_VOLUME=0.5